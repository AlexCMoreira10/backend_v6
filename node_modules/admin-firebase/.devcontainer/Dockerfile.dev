# Use an official Node runtime as the base image
FROM node:18.0

# Set the maintainer label
LABEL maintainer="kovszasz@gmail.com"

# Set environment variables
ENV QENV DEV
ENV PATH="$PATH:/usr/lib/jvm/java-11-openjdk-amd64/bin"

# # Set the user to root
# USER root

# Install system dependencies
RUN apt-get update && \
    apt-get install -y openjdk-11-jre-headless  && \
    apt-get install python3-pip -y

# Copy the current directory contents into the container at /workspaces
# COPY ./ ./workspaces

# Set the working directory in the container to /workspaces
WORKDIR /workspaces/wedding-vera

# Install global npm packages
RUN npm install -g @quasar/cli && \
    npm install -g @vue/cli && \
    npm install -g @vue/cli-init && \
    npm install -g firebase-tools

# Clean npm cache
RUN npm cache clean --force

# Install project dependencies
# RUN npm install

# Link the local 'admin' npm package (submodule)
# WORKDIR /workspaces/wedding-vera/admin-firebase
# RUN npm link
# WORKDIR /workspaces/wedding-vera
# RUN npm link admin-firebase

# Install additional npm packages
RUN npm install @casl/ability && \
    npm install spotify-web-api-node 


# Set the working directory for the functions
# WORKDIR /workspaces/wedding-vera/functions

# Install dependencies for the functions
# RUN npm install

# Set the working directory back to /workspaces
WORKDIR /workspaces/firebase-quasar-admin

# RUN npm install

# USER root
# WORKDIR /workspaces/wedding-vera/admin-firebase
# RUN npm link
# USER 1000
# WORKDIR /workspaces/wedding-vera
# RUN npm link admin-firebase

# Run shell by default when the container starts
CMD /bin/sh

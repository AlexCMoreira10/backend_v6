{
    "name": "firebase-admin-env",
    "customizations": {
        "vscode":{
            "extensions":  ["github.copilot","jcbuisson.vue","ms-vscode.vscode-typescript-next","vue.volar"]
        }
    },
    "dockerFile":"./Dockerfile.dev",
    "context": "..",
    "mounts": [ 
        "source=${localEnv:HOME}/.npmrc,target=/home/node/.npmrc,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind"

    ],
    "containerUser":"1000",
    // "containerUser": "root"
    

}
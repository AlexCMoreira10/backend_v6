deploy-functions:
	cd functions
	firebase deploy --only functions

deploy-hosting:
	QENV=PROD quasar build -m spa
	firebase deploy --only hosting

deploy-db:
	firebase deploy --only storage
	firebase deploy --only database
	firesbase deploy --only firestore:rules

emulate:
	firebase emulators:start --import=./basicdata --export-on-exit

redeploy:
	firebase deploy --only functions
	firebase emulators:start --import=./basicdata --export-on-exit

build:
	firebase functions:config:get > .runtimeconfig.json
	firebase functions:build